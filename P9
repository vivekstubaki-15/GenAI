import wikipedia, requests 
from bs4 import BeautifulSoup 
 
wikipedia.set_user_agent("MyPythonProject/1.0 (student@example.com)") 
 
def fetch_info(name): 
    try: 
        p, s = wikipedia.page(name), wikipedia.summary(name, sentences=2) 
         
        headers = {'User-Agent': 'MyPythonProject/1.0 (student@example.com)'} 
        html_text = requests.get(p.url, headers=headers).text 
         
        # FIX: Added a space between .infobox and tr 
        rows = BeautifulSoup(html_text, 'html.parser').select('.infobox tr') 
         
    except wikipedia.exceptions.DisambiguationError as e: 
        return f"Disambiguation Error: {e.options}" 
    except wikipedia.exceptions.PageError: 
        return f"No page found for '{name}'" 
         
    f, h = "Not Found", "Not Found" 
    for r in rows: 
        th, td = r.find("th"), r.find("td") 
        if not th or not td: 
            continue 
        t = th.text.lower() 
        if "founded" in t or "established" in t: 
            f = td.text.strip() 
        if "headquarters" in t or "location" in t: 
            h = td.text.strip() 
             
    # Expanded the search list to catch more relevant local hits 
    search_cities = ["New York", "London", "Tokyo", "Bangalore", "Bengaluru", "Hubballi", 
"Davangere"] 
    b = [c for c in search_cities if c.lower() in p.content.lower()] or ["Not Found"] 
     
    return f"Name: {name}\nFounded: {f}\nHeadquarters: {h}\nBranches: 
{','.join(b)}\nSummary: {s}" 
 
print(fetch_info(input("Enter institution name:\n"))) 
